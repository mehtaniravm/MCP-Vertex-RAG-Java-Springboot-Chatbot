# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
REGION=us-central1
CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:your-instance

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=your_database
DB_USER=app_user
DB_PASS=fetched-from-secret-manager   # do not set here — use Secret Manager

# ── Vertex AI ────────────────────────────────────────────────────────────────
VERTEX_MODEL=gemini-1.5-flash
RAG_CORPUS_NAME=projects/YOUR_PROJECT/locations/us-central1/ragCorpora/YOUR_CORPUS_ID

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_URL=https://mcp-server-xxx.run.app
BIZ_API_URL=https://biz-data-api-xxx.run.app
BIZ_API_KEY=fetched-from-secret-manager   # leave blank for no-auth mode

# ── Business Data API ────────────────────────────────────────────────────────
API_KEY_ENABLED=true    # set false for no-auth / internal-only mode

# ── Chat API ─────────────────────────────────────────────────────────────────
CHATBOT_API_URL=https://chatbot-api-xxx.run.app

# ── Web Widget ───────────────────────────────────────────────────────────────
WIDGET_THEME=#1A73E8
WIDGET_TITLE=AI Assistant
