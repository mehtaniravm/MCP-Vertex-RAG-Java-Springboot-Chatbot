# GCP
GCP_PROJECT_ID=your-gcp-project-id
CLOUD_SQL_CONNECTION_NAME=project:region:instance
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=app_readonly
DB_PASS=local-dev-only      # production: fetched from Secret Manager
DB_NAME=app_db
DB_PASSWORD_SECRET=postgres-password   # Secret Manager secret name

# Business Data API (Option A)
BIZ_API_URL=http://localhost:8081
BIZ_API_KEY=                           # leave blank for no-auth mode
